# Server
PORT=3001
NODE_ENV=development

# Database (MySQL)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS - URL del frontend (Netlify en prod)
CLIENT_URL=http://localhost:5173
# En Railway: CLIENT_URL y CORS_ORIGINS con la URL de Netlify (ej: https://ethlora.netlify.app)
CORS_ORIGINS=

# Rate limit (solo NODE_ENV=production). Por IP según X-Forwarded-For (trust proxy).
# RATE_LIMIT_MAX=400
# RATE_LIMIT_WINDOW_MS=900000
