# Server
PORT=3001
NODE_ENV=development

# Database (MySQL)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE?schema=public"

# JWT (en producción: secreto aleatorio de ≥32 caracteres; el servidor falla al arrancar si es débil o el default de dev)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS - URL del frontend (Netlify en prod)
CLIENT_URL=http://localhost:5173
# En Railway: CLIENT_URL y CORS_ORIGINS con la URL de Netlify (ej: https://ethlora.netlify.app)
CORS_ORIGINS=

# Rate limit global /api (NODE_ENV=production o FORCE_RATE_LIMIT=true). Por IP (trust proxy).
# RATE_LIMIT_MAX=400
# RATE_LIMIT_WINDOW_MS=900000
# FORCE_RATE_LIMIT=true

# Formulario de contacto (landing) → correo en CONTACT_MAIL_TO
#
# Opción A (recomendada en Railway): API Resend sobre HTTPS (no usa puertos SMTP)
# https://resend.com — dominio verificado; el "from" debe estar permitido en Resend
# RESEND_API_KEY=re_xxxx
# CONTACT_RESEND_FROM=contacto@tudominio.com
#
# Opción B: SMTP (Gmail u otro). En muchos planes gratuitos el host bloquea SMTP saliente.
# Gmail: creá una "Contraseña de aplicación" en la cuenta y usala en CONTACT_SMTP_PASS
CONTACT_MAIL_TO=athlento.app@gmail.com
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_USER=athlento.app@gmail.com
CONTACT_SMTP_PASS=
