{
  "name": "fitcoach-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:catalog": "node prisma/seedCatalogOnly.js",
    "db:seed:catalog:dev": "dotenv -e .env.local -- node prisma/seedCatalogOnly.js",
    "db:studio": "prisma studio",
    "db:push:dev": "dotenv -e .env.local -- prisma db push",
    "db:seed:dev": "dotenv -e .env.local -- node prisma/seed.js",
    "db:studio:dev": "dotenv -e .env.local -- prisma studio",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate deploy"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
