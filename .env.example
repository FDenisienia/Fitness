# Frontend - Athlento
# Debe incluir el sufijo /api (igual que monta Express). Ej.: http://localhost:3001/api
# En desarrollo puedes omitir la variable y se usará el proxy de Vite hacia el backend.
VITE_API_URL=http://localhost:3001/api
# Opcional: nombre de marca en exportación PDF (por defecto: Athlento)
# VITE_APP_BRAND_NAME=Athlento
